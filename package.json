{
  "name": "bg-generator-prod",
  "version": "1.0.0",
  "private": true,
  "description": "Local lint setup for Patternator static assets",
  "scripts": {
    "patterns:generate": "node ./scripts/generate-pattern-manifest.mjs",
    "lint": "npm run lint:css && npm run lint:html",
    "lint:css": "stylelint \"assets/style/**/*.css\"",
    "lint:html": "htmlhint \"index.html\""
  },
  "devDependencies": {
    "htmlhint": "^1.6.3",
    "stylelint": "^16.15.0",
    "stylelint-config-standard": "^37.0.0"
  }
}
